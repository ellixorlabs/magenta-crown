# Copy to .env locally. In Vercel/hosting, set the same keys in Project → Environment Variables (Production).

# Neon
DATABASE_URL="postgresql://..."

# Auth.js / NextAuth v5 — required in production (Google OAuth will fail without it)
# Generate: openssl rand -base64 32
AUTH_SECRET=""

# Canonical site URL (no trailing slash). Critical for OAuth redirects in deployment.
# Example: https://www.yourdomain.com
AUTH_URL="http://localhost:3000"

# Public site URL for sitemap, JSON-LD, Open Graph absolute URLs, and metadataBase.
# In production set to your storefront origin (often same as AUTH_URL). Falls back to AUTH_URL if unset.
# NEXT_PUBLIC_SITE_URL="https://www.yourdomain.com"

# Google OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client)
# 1) Create OAuth client type "Web application".
# 2) Authorized JavaScript origins: e.g. http://localhost:3000 and https://yourdomain.com
# 3) Authorized redirect URIs (exact): http://localhost:3000/api/auth/callback/google and https://yourdomain.com/api/auth/callback/google
# 4) OAuth consent screen: add yourself as a test user while app is in "Testing".
# 5) AUTH_URL must match the origin you use in the browser (no trailing slash). Restart dev server after editing .env.
# 6) AUTH_SECRET must be set (Google sign-in will fail without it in production).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional aliases (auth.ts accepts these too)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
