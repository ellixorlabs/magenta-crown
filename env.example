# Copy to .env locally. In Vercel/hosting, set the same keys in Project → Environment Variables (Production).

# PostgreSQL (Supabase) for Prisma queries.
# - Use Supabase Transaction pooler URL (port 6543) as DATABASE_URL in serverless deployments.
# - For prisma migrate with PgBouncer, add directUrl in schema and set DIRECT_URL to the direct DB URL (port 5432).
# - User.email is already @unique in schema (indexed). Product list indexes: createdAt, category (see prisma/schema.prisma).
DATABASE_URL="postgresql://..."
# Optional: direct Postgres URL for migrations when DATABASE_URL is pooled (e.g. Supabase session mode).
# DIRECT_URL="postgresql://...:5432/..."

# Public site URL for sitemap, JSON-LD, Open Graph absolute URLs, and metadataBase.
# In production set to your storefront origin.
# NEXT_PUBLIC_SITE_URL="https://www.yourdomain.com"

# Supabase Auth (Google OAuth + Email/Password)
# In Supabase dashboard add your site URL and redirect URL:
# - Site URL: http://localhost:3000
# - Redirect URL: http://localhost:3000/auth/callback
#
# Google OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client)
# 1) Create OAuth client type "Web application".
# 2) Authorized JavaScript origins: e.g. http://localhost:3000 and https://yourdomain.com
# 3) Authorized redirect URIs (exact): https://<project-ref>.supabase.co/auth/v1/callback
# 4) OAuth consent screen: add yourself as a test user while app is in "Testing".
# 5) Restart dev server after editing .env.

# Supabase Storage (admin uploads)
# - Buckets expected: `product-images` and `product-videos`
# - Service role key is server-only; never expose in client code.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
