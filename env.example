# Copy to .env locally. In Vercel/hosting, set the same keys in Project → Environment Variables (Production).

# Neon
DATABASE_URL="postgresql://..."

# Auth.js / NextAuth v5 — required in production (Google OAuth will fail without it)
# Generate: openssl rand -base64 32
AUTH_SECRET=""

# Canonical site URL (no trailing slash). Critical for OAuth redirects in deployment.
# Example: https://www.yourdomain.com
AUTH_URL="http://localhost:3000"

# Google OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client)
# Authorized JavaScript origins: https://yourdomain.com
# Authorized redirect URIs: https://yourdomain.com/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional aliases (auth.ts accepts these too)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
